{
  "name": "roses-food-blog",
  "version": "0.1.0",
  "private": true,
  "description": "Deutschsprachiger Food- & Reiseblog mit CMS, CRM und Newsletter",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
