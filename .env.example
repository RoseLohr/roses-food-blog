# ---------------------------------------------------------------------------
# Roses Food Blog — Konfiguration
# Kopieren nach .env und Werte eintragen. NIEMALS die .env committen.
# ---------------------------------------------------------------------------

# Öffentliche Basis-URL der Website (ohne abschließenden Slash)
BASE_URL=https://www.example.de

# Port auf dem Host, an den der Container gebunden wird (nginx proxied dorthin).
# Der Container lauscht nur auf 127.0.0.1:$PORT.
PORT=3000

# Verzeichnis auf dem Host für persistente Daten (SQLite, Uploads, GeoIP-DB).
# Wird von deploy.sh beim Erstlauf angelegt.
DATA_DIR=/srv/roses-blog/data

# Geheimnis für Session-Signierung. Erzeugen mit:  openssl rand -hex 32
SESSION_SECRET=

# ---------------------------------------------------------------------------
# SMTP-Versand (Double-Opt-in, Kampagnen, Sequenzen)
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.example.de
SMTP_PORT=587
SMTP_USER=newsletter@example.de
SMTP_PASS=
# Absenderangabe inkl. Anzeigename
SMTP_FROM="Roses Food Blog <newsletter@example.de>"
# Maximale Mails pro Minute beim Massenversand (Queue-Rate)
EMAIL_RATE_PER_MINUTE=30

# ---------------------------------------------------------------------------
# Initiales Admin-Konto — wird beim Erststart angelegt, falls noch keins existiert
# ---------------------------------------------------------------------------
ADMIN_EMAIL=admin@example.de
ADMIN_PASSWORD=

# Zeitzone für Scheduler und Anzeige
TZ=Europe/Berlin

# ---------------------------------------------------------------------------
# Aktualisierung aus dem Admin-Panel (optional)
# Repository (owner/name) und Branch für die Update-Prüfung. Kann auch später
# im Admin-Panel unter „Einstellungen“ gesetzt werden (DB hat Vorrang).
# Das eigentliche Deployment stößt den Host-Watcher an, der ./deploy.sh startet.
# ---------------------------------------------------------------------------
DEPLOY_REPO=RoseLohr/roses-food-blog
DEPLOY_BRANCH=main

# Auto-Deploy per GitHub-Webhook (optional, aber OHNE dieses Secret AUS).
# Der Webhook /api/deploy-hook verifiziert jede Lieferung per HMAC-SHA256 mit
# diesem Wert. WICHTIG: Dieser Wert MUSS exakt dem „Secret" entsprechen, das im
# GitHub-Webhook hinterlegt ist (Settings → Webhooks → dein Hook → Secret) —
# GitHub signiert damit, der Server verifiziert damit. Fehlt er hier, antwortet
# der Hook mit HTTP 503 „webhook_disabled" (fail-closed) und es wird NICHT
# deployt. Er MUSS in DIESER Datei stehen (der Container liest env via
# `env_file: .env` in compose.yml) — ein Setzen nur in der GitHub-Oberfläche
# reicht NICHT. Nach dem Eintragen ./deploy.sh laufen lassen (Container wird neu
# erstellt, sonst greift die neue .env nicht). Erzeugen mit: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=

# Nur nötig, wenn der ausgelieferte Branch NICHT der Default-Branch des Repos
# ist: erzwingt, auf welchen Push-Branch der Webhook deployt (sonst
# DEPLOY_BRANCH bzw. repository.default_branch → main).
# DEPLOY_HOOK_BRANCH=main

# Optionaler GitHub-Token NUR für die „Neuester Stand"-Prüfung im Panel
# (Anfragelimit 60→5000/h; öffnet private Repos). Bei einem ÖFFENTLICHEN Repo
# nicht nötig — ein ungültiger/abgelaufener Token führt zu HTTP 401 und die
# Prüfung zeigt „unbekannt". Im Zweifel leer lassen. Kann auch im Admin-Panel
# unter „Einstellungen" gesetzt werden (DB hat Vorrang).
# DEPLOY_GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# KI-Rezeptassistent (optional): Anthropic-API-Schlüssel für Claude.
# Kann auch im Admin-Panel unter „Einstellungen → KI-Assistent“ gesetzt werden
# (DB hat Vorrang). Schlüssel erstellen unter console.anthropic.com.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
