# ---------------------------------------------------------------------------
# Roses Food Blog — Konfiguration
# Kopieren nach .env und Werte eintragen. NIEMALS die .env committen.
# ---------------------------------------------------------------------------

# Öffentliche Basis-URL der Website (ohne abschließenden Slash)
BASE_URL=https://www.example.de

# Port auf dem Host, an den der Container gebunden wird (nginx proxied dorthin).
# Der Container lauscht nur auf 127.0.0.1:$PORT.
PORT=3000

# Verzeichnis auf dem Host für persistente Daten (SQLite, Uploads, GeoIP-DB).
# Wird von deploy.sh beim Erstlauf angelegt.
DATA_DIR=/srv/roses-blog/data

# Geheimnis für Session-Signierung. Erzeugen mit:  openssl rand -hex 32
SESSION_SECRET=

# ---------------------------------------------------------------------------
# SMTP-Versand (Double-Opt-in, Kampagnen, Sequenzen)
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.example.de
SMTP_PORT=587
SMTP_USER=newsletter@example.de
SMTP_PASS=
# Absenderangabe inkl. Anzeigename
SMTP_FROM="Roses Food Blog <newsletter@example.de>"
# Maximale Mails pro Minute beim Massenversand (Queue-Rate)
EMAIL_RATE_PER_MINUTE=30

# ---------------------------------------------------------------------------
# Initiales Admin-Konto — wird beim Erststart angelegt, falls noch keins existiert
# ---------------------------------------------------------------------------
ADMIN_EMAIL=admin@example.de
ADMIN_PASSWORD=

# Zeitzone für Scheduler und Anzeige
TZ=Europe/Berlin
